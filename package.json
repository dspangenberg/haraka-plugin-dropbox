{
  "name": "haraka-plugin-dropbox",
  "version": "1.1.0",
  "description": "Haraka plugin that forwards incoming emails to configured Dropbox webhook URLs",
  "main": "index.js",
  "files": [
    "CHANGELOG.md",
    "config"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint *.js test --fix",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "test": "node --test",
    "test:coverage": "HARAKA_COVERAGE=1 npx c8 npm test",
    "versions": "npx dependency-version-checker check",
    "versions:fix": "npx dependency-version-checker update"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dspangenberg/haraka-plugin-dropbox.git"
  },
  "keywords": [
    "haraka-plugin",
    "dropbox"
  ],
  "author": "Danny Spangenberg <danny.spangenberg@twiceware.de>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dspangenberg/haraka-plugin-dropbox/issues"
  },
  "homepage": "https://github.com/dspangenberg/haraka-plugin-dropbox#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@haraka/eslint-config": "^2.0.2",
    "globals": "^17.4.0",
    "haraka-test-fixtures": "^1.3.10",
    "smtp-client": "^0.4.0"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  },
  "dependencies": {
    "axios": "^1.14.0",
    "email-forward-parser": "github:dspangenberg/email-forward-parser#95616654c0557e93b29897d640775332ef8868e8",
    "email-reply-parser": "github:dspangenberg/email-reply-parser#da7cd3ebc7c9ec4f29d19b2ed0d4aa18efb5b5a4",
    "haraka-dsn": "^1.1.0",
    "mailparser": "^3.9.6",
    "re2": "1.23.3",
    "safe-stringify": "^1.3.0"
  }
}
